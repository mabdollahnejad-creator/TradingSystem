<Window x:Class="TradingSystem.Presentation.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Trading System Pro" Height="700" Width="1100"
        WindowStartupLocation="CenterScreen"
        Background="#F3F4F6">
    <!-- Light Gray Background -->

    <Window.Resources>
        <!-- استایل مدرن برای دکمه‌ها -->
        <Style x:Key="ModernButton" TargetType="Button">
            <Setter Property="Background" Value="#FFFFFF"/>
            <Setter Property="Foreground" Value="#374151"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="15,10"/>
            <Setter Property="Margin" Value="0,5"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#E5E7EB"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="PrimaryButton" TargetType="Button">
            <Setter Property="Background" Value="#2563EB"/>
            <!-- Modern Blue -->
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="20,10"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#1D4ED8"/>
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Background" Value="#9CA3AF"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <!-- ستون سایدبار (عرض آن با کد تغییر می‌کند) -->
            <ColumnDefinition x:Name="SidebarColumn" Width="220"/>
            <ColumnDefinition Width="5"/>
            <!-- Separator -->
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="35"/>
            <!-- Status Bar -->
        </Grid.RowDefinitions>

        <!-- 1. Sidebar -->
        <Border Grid.Column="0" Grid.Row="0" Background="#FFFFFF" BorderBrush="#E5E7EB" BorderThickness="0,0,1,0">
            <DockPanel>
                <!-- Toggle Button for Sidebar -->
                <Button DockPanel.Dock="Top" Content="☰" Background="Transparent" BorderThickness="0" 
                        FontSize="20" HorizontalAlignment="Right" Margin="10" Cursor="Hand"
                        Click="ToggleSidebar_Click" ToolTip="Toggle Sidebar"/>

                <StackPanel Margin="15,10">
                    <TextBlock Text="TRADING PRO" FontWeight="Bold" FontSize="18" Foreground="#2563EB" Margin="0,0,0,30"/>

                    <Button Content="📊 Chart" Style="{StaticResource ModernButton}" Click="NavChart_Click"/>
                    <Button Content="💾 Data Management" Style="{StaticResource ModernButton}" Click="NavData_Click"/>
                    <Button Content="🔬 Backtest" Style="{StaticResource ModernButton}" IsEnabled="False" Foreground="#9CA3AF"/>
                    <Button Content="👁️ Watchlist" Style="{StaticResource ModernButton}" IsEnabled="False" Foreground="#9CA3AF"/>
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- Separator Line -->
        <Border Grid.Column="1" Grid.Row="0" Background="#E5E7EB"/>

        <!-- 2. Main Content Area -->
        <Border Grid.Column="2" Grid.Row="0" Background="#F3F4F6">
            <ContentControl x:Name="MainContent" />
        </Border>

        <!-- 3. Status Bar -->
        <Border Grid.Column="0" Grid.ColumnSpan="3" Grid.Row="1" Background="#2563EB">
            <TextBlock x:Name="StatusBarText" Text="System Ready." VerticalAlignment="Center" Margin="15,0" Foreground="White" FontSize="12"/>
        </Border>
    </Grid>
</Window>