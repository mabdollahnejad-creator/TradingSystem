<UserControl x:Class="TradingSystem.Presentation.Views.DataPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#F3F4F6">

    <UserControl.Resources>
        <Style x:Key="ModernButton" TargetType="Button">
            <Setter Property="Background" Value="#FFFFFF"/>
            <Setter Property="Foreground" Value="#374151"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="#D1D5DB"/>
            <Setter Property="Padding" Value="12,6"/>
            <Setter Property="Margin" Value="0,3"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#F9FAFB"/>
                    <Setter Property="BorderBrush" Value="#9CA3AF"/>
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Foreground" Value="#9CA3AF"/>
                    <Setter Property="Cursor" Value="Arrow"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="PrimaryButton" TargetType="Button">
            <Setter Property="Background" Value="#2563EB"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="15,7"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#1D4ED8"/>
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Background" Value="#9CA3AF"/>
                    <Setter Property="Cursor" Value="Arrow"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="CancelButton" TargetType="Button">
            <Setter Property="Background" Value="#DC2626"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="15,7"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#B91C1C"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="CompactCard" TargetType="Border">
            <Setter Property="Background" Value="White"/>
            <Setter Property="CornerRadius" Value="6"/>
            <Setter Property="Padding" Value="15,10"/>
            <Setter Property="Margin" Value="0,0,0,10"/>
            <Setter Property="BorderBrush" Value="#E5E7EB"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>
    </UserControl.Resources>

    <Grid>
        <ScrollViewer x:Name="MainScrollViewer" Padding="20" VerticalScrollBarVisibility="Auto">
            <ScrollViewer.Style>
                <Style TargetType="ScrollViewer">
                    <Setter Property="IsEnabled" Value="True"/>
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsBusy}" Value="True">
                            <Setter Property="IsEnabled" Value="False"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </ScrollViewer.Style>

            <StackPanel MaxWidth="700" HorizontalAlignment="Center">

                <TextBlock Text="Data Management" FontSize="20" FontWeight="Bold" Foreground="#111827" Margin="0,0,0,12"/>

                <Border Style="{StaticResource CompactCard}">
                    <StackPanel>
                        <TextBlock Text="Metadata Sync (CoinGecko)" FontSize="14" FontWeight="SemiBold" Foreground="#374151" Margin="0,0,0,8"/>

                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="100"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Top Count:" VerticalAlignment="Center" Foreground="#6B7280" FontSize="13"/>
                            <ComboBox Grid.Column="1" ItemsSource="{Binding TopCounts}" SelectedItem="{Binding SelectedTopCount}" 
                                      Padding="8,5" FontSize="13" Background="#F9FAFB" BorderBrush="#D1D5DB"/>
                            <Button Grid.Column="2" Content="Sync Metadata" Style="{StaticResource PrimaryButton}" Width="140" Margin="10,0,0,0"
                                    Command="{Binding SyncMetadataCommand}"/>
                           
                        </Grid>
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource CompactCard}" BorderBrush="#F59E0B" BorderThickness="2">
                    <StackPanel>
                        <TextBlock Text="📅 Global Date Range (Applies to All Downloads)" FontSize="14" FontWeight="SemiBold" Foreground="#D97706" Margin="0,0,0,8"/>
                        <TextBlock Text="This date range applies to both Custom Symbol and Top N downloads." 
                                   Foreground="#92400E" FontSize="12" Margin="0,0,0,8"/>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="60"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="20"/>
                                <ColumnDefinition Width="60"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <TextBlock Grid.Column="0" Text="From:" VerticalAlignment="Center" Foreground="#6B7280" FontSize="13"/>
                            <DatePicker Grid.Column="1" SelectedDate="{Binding FromDate}" 
                                        Language="en-GB" SelectedDateFormat="Short"
                                        Padding="6,4" FontSize="13" Background="#F9FAFB" BorderBrush="#D1D5DB"/>

                            <TextBlock Grid.Column="3" Text="To:" VerticalAlignment="Center" Foreground="#6B7280" FontSize="13"/>
                            <DatePicker Grid.Column="4" SelectedDate="{Binding ToDate}" 
                                        Language="en-GB" SelectedDateFormat="Short"
                                        Padding="6,4" FontSize="13" Background="#F9FAFB" BorderBrush="#D1D5DB"/>
                        </Grid>
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource CompactCard}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Bulk Download (Top Ranked)" FontSize="14" FontWeight="SemiBold" Foreground="#374151" Margin="0,0,0,5"/>
                            <TextBlock Text="Downloads top N cryptocurrencies automatically from all sources." 
                                       Foreground="#6B7280" TextWrapping="Wrap" FontSize="12"/>
                        </StackPanel>

                        <Button Grid.Column="1" Content="Download Top N" Style="{StaticResource PrimaryButton}" Width="160"
                                Command="{Binding DownloadTopCommand}" />
                    </Grid>
                </Border>

                <Border Style="{StaticResource CompactCard}">
                    <StackPanel>
                        <TextBlock Text="Custom Symbol Download" FontSize="14" FontWeight="SemiBold" Foreground="#374151" Margin="0,0,0,8"/>

                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="60"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Symbol:" VerticalAlignment="Center" Foreground="#6B7280" FontSize="13"/>
                            <TextBox Grid.Column="1" Text="{Binding CustomSymbol, UpdateSourceTrigger=PropertyChanged}" 
                                     Padding="6,4" FontSize="13" Background="#F9FAFB" BorderBrush="#D1D5DB" ToolTip="e.g., BTC"/>
                            <Button Grid.Column="2" Content="Download Symbol" Style="{StaticResource PrimaryButton}" Width="160" Margin="10,0,0,0"
                                    Command="{Binding DownloadCustomCommand}" />
                            
                        </Grid>

                        <TextBlock Text="Downloads from ALL exchanges (Binance, Nobitex, Wallex) and timeframes (1H, 4H, 1D)." 
                                   Foreground="#6B7280" TextWrapping="Wrap" FontSize="12"/>
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource CompactCard}">
                    <StackPanel>
                        <TextBlock Text="Backup &amp; Restore (CSV)" FontSize="14" FontWeight="SemiBold" Foreground="#374151" Margin="0,0,0,8"/>
                        <TextBlock Text="Export all data to CSV for backup, or import previously exported data." 
                                   Foreground="#6B7280" TextWrapping="Wrap" FontSize="12" Margin="0,0,0,8"/>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <TextBlock Grid.Column="0" Text="Files saved in: Data/ folder (organized by exchange/timeframe)" 
                                       Foreground="#6B7280" FontSize="12" VerticalAlignment="Center"/>

                            <Button Grid.Column="1" Content="📤 Export to CSV" Style="{StaticResource ModernButton}" Width="140" Margin="0,0,8,0"
                                    Command="{Binding ExportAllCommand}"/>

                            <Button Grid.Column="2" Content="📥 Import from CSV" Style="{StaticResource ModernButton}" Width="140"
                                    Command="{Binding ImportAllCommand}"/>
                        </Grid>
                    </StackPanel>
                </Border>

            </StackPanel>
        </ScrollViewer>

        <!-- ✅ Loading Overlay -->
        <Border Background="#CCF3F4F6" 
        Visibility="{Binding IsBusy, Converter={StaticResource BooleanToVisibilityConverter}}"
        Cursor="Wait">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Width="650">

                <TextBlock Text="⏳" FontSize="40" Foreground="#64748B" 
                   HorizontalAlignment="Center" Margin="0,0,0,15"/>

                <TextBlock Text="{Binding LoadingMessage}" 
                   FontSize="16" FontWeight="SemiBold" Foreground="#1E293B" 
                   HorizontalAlignment="Center" TextWrapping="Wrap" 
                   TextAlignment="Center" Margin="0,0,0,15"/>

                <!-- ✅ لیست با ارتفاع ثابت -->
                <Border Background="#FFFFFF" CornerRadius="8" Padding="10" Margin="0,0,0,12" 
                BorderBrush="#E2E8F0" BorderThickness="1" Height="420">
                    <ItemsControl ItemsSource="{Binding ActiveDownloadsList}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Background="#F8FAFC" CornerRadius="6" Padding="8,8" Margin="0,3"
                                BorderBrush="#E2E8F0" BorderThickness="1">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>

                                        <!-- ✅ اصلاح: حذف duplicate -->
                                        <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                            <TextBlock FontSize="13" FontWeight="Medium" Foreground="#334155">
                                        <Run Text="{Binding Symbol}"/>
                                        <Run Text=" - " Foreground="#94A3B8"/>
                                        <Run Text="{Binding Exchange}"/>
                                        <Run Text=" - " Foreground="#94A3B8"/>
                                        <Run Text="{Binding Timeframe}"/>
                                            </TextBlock>
                                            <TextBlock Text="{Binding LastProcessedDate, StringFormat=' {0}'}" 
                                               FontSize="11" Foreground="#64748B" Margin="0,3,0,0"/>
                                        </StackPanel>

                                        <TextBlock Grid.Column="1" Text="{Binding Status}" 
                                           FontSize="11" Foreground="#475569" 
                                           VerticalAlignment="Center" TextAlignment="Right"/>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </Border>

                <ProgressBar IsIndeterminate="False" 
                     Value="{Binding ProgressValue}" Maximum="100"
                     Width="600" Height="8" Margin="0,0,0,15"
                     Foreground="#3B82F6" Background="#E2E8F0"/>

                <TextBlock Text="{Binding StatusMessage}" 
                   FontSize="13" Foreground="#475569" 
                   HorizontalAlignment="Center" TextWrapping="Wrap" 
                   TextAlignment="Center" Margin="0,0,0,20"/>

                <TextBlock Text="{Binding CurrentFileName, StringFormat='📁 {0}'}" 
                   FontSize="14" FontWeight="Bold" Foreground="#1E293B" 
                   HorizontalAlignment="Center" Margin="0,0,0,10"/>

                <Button Content="✕ Cancel Operation" 
                Style="{StaticResource CancelButton}"
                Width="180" Height="36"
                HorizontalAlignment="Center"
                Command="{Binding CancelOperationCommand}"
                Visibility="{Binding IsCancellable, Converter={StaticResource BooleanToVisibilityConverter}}"/>
            </StackPanel>
        </Border>

        <!-- ✅ Report Message - خارج از Loading Overlay -->
        <Border Background="#F0FDF4" 
        CornerRadius="8" 
        Padding="20" 
        Margin="20"
        BorderBrush="#86EFAC" 
        BorderThickness="2"
        Visibility="{Binding ReportMessage, Converter={StaticResource StringNotEmptyToVisibilityConverter}}"
        VerticalAlignment="Bottom"
        HorizontalAlignment="Center"
        MaxWidth="700">
            <ScrollViewer VerticalScrollBarVisibility="Auto" MaxHeight="300">
                <TextBlock Text="{Binding ReportMessage}" 
                   FontSize="12" 
                   Foreground="#166534" 
                   TextWrapping="Wrap" 
                   FontFamily="Consolas"/>
            </ScrollViewer>
        </Border>
    </Grid>
</UserControl>